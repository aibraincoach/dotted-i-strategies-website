{
  "version": 2,
  "public": true,
  "github": {
    "enabled": false
  },
  "routes": [
    {
      "src": "/",
      "dest": "/public/index.html"
    },
    {
      "src": "/services",
      "dest": "/public/services.html"
    },
    {
      "src": "/purpose",
      "dest": "/public/purpose.html"
    },
    {
      "src": "/access-to",
      "dest": "/public/access-to.html"
    },
    {
      "src": "/insights",
      "dest": "/public/insights.html"
    },
    {
      "src": "/connect",
      "dest": "/public/connect.html"
    },
    {
      "src": "/([^/]+)",
      "dest": "/public/$1.html"
    }
  ]
}
